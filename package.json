{
  "name": "duplex-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A terminal-native dual-agent orchestrator for Codex-style workflows.",
  "bin": {
    "duplex-codex": "bin/duplex-codex.js",
    "duplex-codex-codex": "bin/duplex-codex-codex.js",
    "duplex-codex-gemini": "bin/duplex-codex-gemini.js",
    "duplex-codex-claude": "bin/duplex-codex-claude.js",
    "duplex-gemini-codex": "bin/duplex-gemini-codex.js",
    "duplex-gemini-gemini": "bin/duplex-gemini-gemini.js",
    "duplex-gemini-claude": "bin/duplex-gemini-claude.js",
    "duplex-claude-codex": "bin/duplex-claude-codex.js",
    "duplex-claude-gemini": "bin/duplex-claude-gemini.js",
    "duplex-claude-claude": "bin/duplex-claude-claude.js",
    "duplex-msg": "bin/duplex-msg.js"
  },
  "scripts": {
    "cli": "node bin/duplex-codex.js",
    "msg": "node bin/duplex-msg.js",
    "start": "node --experimental-strip-types src/app/bootstrap.ts",
    "dev": "node --watch --experimental-strip-types src/app/bootstrap.ts",
    "test": "node --test --test-isolation=none --experimental-strip-types test/cli.test.ts test/msg-cli.test.ts test/broker.test.ts test/coordinator.test.ts test/codex-cli-provider.test.ts test/agent-session.test.ts test/terminal-ui.test.ts test/verification.test.ts",
    "verify:long": "node --experimental-strip-types src/app/verifyLongRun.ts",
    "verify:matrix": "node --experimental-strip-types src/app/verifyMatrix.ts"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@xterm/headless": "^6.0.0",
    "node-pty": "^1.1.0"
  }
}
